# The port your backend server will run on (used in server.js)
PORT=5000

# Your MongoDB connection string (used in utils/db.js)
# IMPORTANT: Never hardcode your real password in the code.
MONGO_URI=mongodb://localhost:27017/skribbl-clone

# The URL of your frontend application to allow CORS requests (used in app.js and server.js)
CLIENT_URL=http://localhost:5173
